{
  "manifest_version": 2,
  "name": "Zen Tabs Bridge",
  "version": "0.1.0",
  "description": "Streams live open-tab data from Zen to a native messaging host for external tools (e.g. Raycast).",

  "browser_specific_settings": {
    "gecko": {
      "id": "zen-tabs-bridge@yourname",
      "strict_min_version": "109.0"
    }
  },

  "permissions": ["tabs", "nativeMessaging"],

  "background": {
    "scripts": ["background.js"],
    "persistent": true
  }
}
